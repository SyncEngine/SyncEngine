{% extends 'base.html.twig' %}

{% block title %}{{ 'Modules'|trans({},'core') }}{% endblock %}

{% block body %}
	<div class="card my-3">
		<div class="card-header bg-primary-subtle d-flex justify-content-between align-items-center">
			<div class="d-flex align-items-center gap-2"><i class="bi bi-plugin lead"></i> {{ 'Modules'|trans({},'core') }}</div>
			<a class="btn btn-primary" href="{{ path('module_upload') }}">{{ 'Upload'|trans({},'core') }}</a></div>
		<div class="card-body">
			<table class="table table-hover table-responsive align-middle">
				<tr>
					<th>{{ 'Name'|trans({},'core') }}</th>
					<th>{{ 'Description'|trans({},'core') }}</th>
					<th>{{ 'Version'|trans({},'core') }}</th>
					<th>{{ 'Author'|trans({},'core') }}</th>
					<th class="text-end">{{ 'Actions'|trans({},'core') }}</th>
				</tr>
				{% for module in modules %}
					{% if module.name %}
					<tr>
						<td>{{ module.name }}</td>
						<td>{{ module.description }}</td>
						<td>{{ module.version }}</td>
						<td>{{ module.author }}</td>
						<td class="text-end">
							<a class="btn btn-primary" href="{{ path('module', {name:module.name}) }}"><i class="bi-pencil-fill"></i></a>
						</td>
					</tr>
					{% endif %}
				{% endfor %}
			</table>
		</div>
	</div>
{% endblock %}
