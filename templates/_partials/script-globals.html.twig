<script id="script_globals">
	var APP_BASE_URL = "{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}";

	// Form changes
	var changedForms = [];
	function beforeUnloadForm( element ) {
		var ref = element.id + '_' + element.name;
		element.addEventListener( 'change', function() { changedForms.push( ref ); }, false );
		element.addEventListener( 'submitted', function() { changedForms.splice( changedForms.indexOf( ref ), 1 ); }, false );
		element.addEventListener( 'removed', function() { changedForms.splice( changedForms.indexOf( ref ), 1 ); }, false );
	}
	window.onbeforeunload = function() {
		if ( changedForms.length ) {
			return 'You have unsaved changes! If you leave this page, your changes will be lost.';
		}
	};
	window.addEventListener( 'load', function() {
		Array.from( document.getElementsByTagName( 'form' ) ).forEach( function( form ) {
			beforeUnloadForm( form );
		} )
	} );
</script>
