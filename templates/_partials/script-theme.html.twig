<script>
	(() => {
		'use strict'

		if ( 'undefined' === typeof window.app.theme ) {
			window.app.theme = {};
		}

		window.app.theme.getStoredTheme = function() { return localStorage.getItem('theme') };
		window.app.theme.setStoredTheme = function( theme ) { localStorage.setItem('theme', theme) };

		window.app.theme.getPreferredTheme = function() {
			var storedTheme = window.app.theme.getStoredTheme();
			if ( storedTheme ) {
				return storedTheme;
			}

			return window.app.theme.getAutoTheme();
		}

		window.app.theme.getAutoTheme = function() {
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		}

		window.app.theme.getTheme = function() {
			return document.documentElement.getAttribute('data-bs-theme');
		}

		window.app.theme.setTheme = function( theme ) {
			if ( theme === 'auto' ) {
				document.documentElement.setAttribute('data-bs-theme', window.app.theme.getAutoTheme() );
			} else {
				document.documentElement.setAttribute('data-bs-theme', theme);
			}
		}

		window.app.theme.updateTheme = function( theme ) {
			window.app.theme.setTheme( theme );
			window.app.theme.setStoredTheme( theme );
		}

		window.app.theme.setTheme( window.app.theme.getPreferredTheme() );

		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
			var storedTheme = window.app.theme.getStoredTheme();
			if ( storedTheme !== 'light' && storedTheme !== 'dark' ) {
				window.app.theme.setTheme( window.app.theme.getPreferredTheme() );
			}
		})
	})()
</script>
