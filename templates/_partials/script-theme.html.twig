<script>
	(() => {
		'use strict'

		if ( 'undefined' === typeof window.bootstrap ) {
			window.bootstrap = {};
		}

		window.bootstrap.getStoredTheme = function() { return localStorage.getItem('theme') };
		window.bootstrap.setStoredTheme = function( theme ) { localStorage.setItem('theme', theme) };

		window.bootstrap.getPreferredTheme = function() {
			var storedTheme = window.bootstrap.getStoredTheme();
			if ( storedTheme ) {
				return storedTheme;
			}

			return window.bootstrap.getAutoTheme();
		}

		window.bootstrap.getAutoTheme = function() {
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		}

		window.bootstrap.getTheme = function() {
			return document.documentElement.getAttribute('data-bs-theme');
		}

		window.bootstrap.setTheme = function( theme ) {
			if ( theme === 'auto' ) {
				document.documentElement.setAttribute('data-bs-theme', window.bootstrap.getAutoTheme() );
			} else {
				document.documentElement.setAttribute('data-bs-theme', theme);
			}
		}

		window.bootstrap.updateTheme = function( theme ) {
			window.bootstrap.setTheme( theme );
			window.bootstrap.setStoredTheme( theme );
		}

		window.bootstrap.setTheme( window.bootstrap.getPreferredTheme() );

		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
			var storedTheme = window.bootstrap.getStoredTheme();
			if ( storedTheme !== 'light' && storedTheme !== 'dark' ) {
				window.bootstrap.setTheme( window.bootstrap.getPreferredTheme() );
			}
		})
	})()
</script>
