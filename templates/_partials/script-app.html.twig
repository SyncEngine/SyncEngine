<script id="script-syncengine-app">
	window.SyncEngine = {
		env: "{{ app.environment }}",
		debug: {{ app.debug ? 'true' : 'false' }},
		__expirimental: {{ __expirimental ? 'true' : 'false' }},
		baseUrl: "{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}",
		icons: {{ icons|json_encode|raw }},
		endpoints: {
			models: {
				blueprints: "{{ url( 'syncengine_json_blueprints' ) }}",
				columns: "{{ url( 'syncengine_json_columns' ) }}",
				tasks: "{{ url( 'syncengine_json_tasks' ) }}",
				webservices: "{{ url( 'syncengine_json_webservices' ) }}",
			},
			entities: {
				automation: "{{ url( 'syncengine_json_automation' ) }}",
				connection: "{{ url( 'syncengine_json_connection' ) }}",
				flow: "{{ url( 'syncengine_json_flow' ) }}",
				step: "{{ url( 'syncengine_json_step' ) }}",
				storage: "{{ url( 'syncengine_json_storage' ) }}",
				trace: "{{ url( 'syncengine_json_trace' ) }}",
			},
			requests: {
				preview: "{{ url( 'syncengine_json_preview' ) }}",
				webservice: {
					retrieve: "{{ url( 'syncengine_json_webservice_retrieve' ) }}",
				}
			},
			user: {
				preferences: "{{ url( 'syncengine_json_preferences' ) }}",
			},
			secrets: {
				list: "{{ url( 'syncengine_json_secrets' ) }}",
				set: "{{ url( 'syncengine_json_secrets_set' ) }}",
				unset: "{{ url( 'syncengine_json_secrets_unset' ) }}",
				export: "{{ url( 'syncengine_json_secrets_export' ) }}"
			}
		},
		models: {},
		entities: {},
		labels: {},
		forms: {
			register: function ( element ) {
				var ref = element.id + '_' + element.name;

				function remove() {
					window.SyncEngine.forms.changed.splice(
						window.SyncEngine.forms.changed.indexOf( ref ),
						1,
					);
				}

				function add() {
					if ( ! window.SyncEngine.forms.changed.includes( ref ) ) {
						window.SyncEngine.forms.changed.push( ref );
					}
				}

				// Native.
				element.addEventListener( 'change', add, false );
				element.addEventListener( 'submit', window.SyncEngine.forms.clear, false );
				// AJAX/React
				element.addEventListener( 'submitted', remove, false );
				element.addEventListener( 'removed', remove, false );
			},
			clear: function () { window.SyncEngine.forms.changed = []; },
			changed: [],
		},
		context: {
			register: function ( ref, value ) { window.SyncEngine.context.refs[ ref ] = value; },
			clear: function ( ref ) { delete window.SyncEngine.context.refs[ ref ]; },
			get: function ( ref ) { return window.SyncEngine.context.refs[ ref ] ?? {}; },
			refs: {},
		},
		preferences: {
			menuCollapsed: 1 == localStorage.getItem( 'menu-collapsed' ),
			language: navigator && navigator.language || 'en',
		},
		theme: {
			getStoredTheme: function () { return localStorage.getItem( 'theme' ); },
			setStoredTheme: function ( theme ) { localStorage.setItem( 'theme', theme ); },
			getPreferredTheme: function () {
				return window.SyncEngine.theme.getStoredTheme() || window.SyncEngine.theme.getAutoTheme();
			},
			getAutoTheme: function () {
				return window.matchMedia( '(prefers-color-scheme: dark)' ).matches ? 'dark' : 'light';
			},
			getTheme: function () {
				return document.documentElement.getAttribute( 'data-bs-theme' );
			},
			setTheme: function ( theme ) {
				document.documentElement.setAttribute(
					'data-bs-theme',
					theme === 'auto' ? window.SyncEngine.theme.getAutoTheme() : theme,
				);
			},
			updateTheme: function ( theme ) {
				window.SyncEngine.theme.setTheme( theme );
				window.SyncEngine.theme.setStoredTheme( theme );
			},
		},
		breakpoints: {
			list: {},
			get: function ( size ) {
				var list = window.SyncEngine.breakpoints.list;

				if ( list.hasOwnProperty( size ) ) {
					return list[ size ];
				}

				if ( isNaN( size ) ) {
					list[ size ] = parseInt(
						getComputedStyle(document.documentElement).getPropertyValue( '--bs-breakpoint-' + size ),
						10
					);
				} else {
					list[ size ] = parseInt( size, 10 );
				}

				return list[ size ];
			},
		},
		translations: {},
		hooks: {{ render(controller( 'SyncEngine\\Controller\\HooksController::getThemeHooks', { hookNames: 'sidebar_bottom' } )) }},
		init: function () {
			var menu = document.getElementById( 'menu' );
			if ( menu ) {
				menu.classList.add( window.SyncEngine.preferences.menuCollapsed ? 'collapsed' : 'expanded' );
				document.getElementById( 'main' ).classList.add( window.SyncEngine.preferences.menuCollapsed ? 'menu-collapsed' : 'menu-expanded' );
			}

			Array.from( document.getElementsByTagName( 'form' ) ).forEach( function ( form ) {
				window.SyncEngine.forms.register( form );
			} );

			document.dispatchEvent( new CustomEvent( 'SyncEngine.init' ) );
		},
	};

	window.SyncEngine.theme.setTheme( window.SyncEngine.theme.getPreferredTheme() );

	window.matchMedia( '(prefers-color-scheme: dark)' ).addEventListener( 'change', () => {
		var storedTheme = window.SyncEngine.theme.getStoredTheme();
		if ( storedTheme !== 'light' && storedTheme !== 'dark' ) {
			window.SyncEngine.theme.setTheme( window.SyncEngine.theme.getPreferredTheme() );
		}
	} );

	window.onbeforeunload = function () {
		if ( window.SyncEngine.forms.changed.length ) {
			return 'You have unsaved changes! If you leave this page, your changes will be lost.';
		}
	};
</script>
