<script id="script_globals">
	window.app = {
		env: "{{ app.environment }}",
		debug: {{ app.debug ? 'true' : 'false' }},
		baseUrl: "{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}",
		endpoints: {
			models: {
				tasks: "{{ url( 'json_tasks' ) }}",
				webservices: "{{ url( 'json_webservices' ) }}",
			},
			entities: {
				automation: "{{ url( 'json_automation' ) }}",
				connection: "{{ url( 'json_connection' ) }}",
				flow: "{{ url( 'json_flow' ) }}",
				step: "{{ url( 'json_step' ) }}",
				dataset: "{{ url( 'json_dataset' ) }}",
			},
			requests: {
				automation: "{{ url( 'api_automation' ) }}",
				connection: "{{ url( 'api_connection' ) }}",
				dataset: "{{ url( 'api_dataset' ) }}",
				preview: "{{ url( 'json_preview' ) }}",
			},
		},
		models: {},
		entities: {},
		labels: {},
		forms: {
			register: function( element ) {
				var ref = element.id + '_' + element.name;

				function remove() {
					window.app.forms.changed.splice(
						window.app.forms.changed.indexOf( ref ),
						1,
					);
				}

				function add() { window.app.forms.changed.push( ref ); }

				// Native.
				element.addEventListener( 'change', add, false );
				element.addEventListener( 'submit', window.app.forms.clear, false );
				// AJAX/React
				element.addEventListener( 'submitted', remove, false );
				element.addEventListener( 'removed', remove, false );
            },
			clear: function() { window.app.forms.changed = [] },
			changed: [],
		},
        context: {
			register: function( ref, value ) { window.app.context.refs[ ref ] = value },
			clear: function ( ref ) { delete window.app.context.refs[ ref ] },
			get: function ( ref ) { return window.app.context.refs[ ref ] ?? {} },
			refs: {},
        },
		preferences: {
			menuCollapsed: 1 == localStorage.getItem( 'menu-collapsed' ),
		},
        theme: {
	        getStoredTheme: function() { return localStorage.getItem('theme') },
	        setStoredTheme: function( theme ) { localStorage.setItem('theme', theme) },
	        getPreferredTheme: function() {
				return window.app.theme.getStoredTheme() || window.app.theme.getAutoTheme();
	        },
	        getAutoTheme: function() {
		        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	        },
	        getTheme: function() {
		        return document.documentElement.getAttribute( 'data-bs-theme' );
	        },
	        setTheme: function( theme ) {
		        document.documentElement.setAttribute( 'data-bs-theme', theme === 'auto' ? window.app.theme.getAutoTheme() : theme );
	        },
	        updateTheme: function( theme ) {
		        window.app.theme.setTheme( theme );
		        window.app.theme.setStoredTheme( theme );
	        },
        },
		init: function () {
			var menu = document.getElementById( 'menu' );
			if ( menu ) {
				menu.classList.add( window.app.preferences.menuCollapsed ? 'collapsed' : 'expanded' );
				document.getElementById( 'main' ).classList.add( window.app.preferences.menuCollapsed ? 'menu-collapsed' : 'menu-expanded' );
			}

			Array.from( document.getElementsByTagName( 'form' ) ).forEach( function ( form ) {
				window.app.forms.register( form );
			} );
		},
	};

	window.app.theme.setTheme( window.app.theme.getPreferredTheme() );

	window.matchMedia('(prefers-color-scheme: dark)').addEventListener( 'change', () => {
		var storedTheme = window.app.theme.getStoredTheme();
		if ( storedTheme !== 'light' && storedTheme !== 'dark' ) {
			window.app.theme.setTheme( window.app.theme.getPreferredTheme() );
		}
	} );

	window.onbeforeunload = function () {
		if ( window.app.forms.changed.length ) {
			return 'You have unsaved changes! If you leave this page, your changes will be lost.';
		}
	};
</script>
