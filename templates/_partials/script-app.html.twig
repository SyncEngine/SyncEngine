<script id="script_globals">
	window.app = {
		env: "{{ app.environment }}",
		debug: {{ app.debug ? 'true' : 'false' }},
		baseUrl: "{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}",
		endpoints: {
			models: {
				tasks: "{{ url( 'json_tasks' ) }}",
				webservices: "{{ url( 'json_webservices' ) }}",
            },
			entities: {
				automation: "{{ url( 'json_automation' ) }}",
				connection: "{{ url( 'json_connection' ) }}",
				flow: "{{ url( 'json_flow' ) }}",
				step: "{{ url( 'json_step' ) }}",
				dataset: "{{ url( 'json_dataset' ) }}",
			},
			requests: {
				automation: "{{ url( 'api_automation' ) }}",
				connection: "{{ url( 'api_connection' ) }}",
				dataset: "{{ url( 'api_dataset' ) }}",
			}
		},
		entities: {},
		models: {},
		changedForms: [],
        menuCollapsed: 1 == localStorage.getItem('menu-collapsed'),
	};

	// Form changes
	function beforeUnloadForm( element ) {
		var ref = element.id + '_' + element.name;
		element.addEventListener( 'change', function() { window.app.changedForms.push( ref ); }, false );
		// AJAX/React
		element.addEventListener( 'submitted', function() { window.app.changedForms.splice( window.app.changedForms.indexOf( ref ), 1 ); }, false );
		element.addEventListener( 'removed', function() { window.app.changedForms.splice( window.app.changedForms.indexOf( ref ), 1 ); }, false );
		// Native.
		element.addEventListener( 'submit', function() { window.app.changedForms = []; }, false );
	}
	window.onbeforeunload = function() {
		if ( window.app.changedForms.length ) {
			return 'You have unsaved changes! If you leave this page, your changes will be lost.';
		}
	};
	window.addEventListener( 'load', function() {
		Array.from( document.getElementsByTagName( 'form' ) ).forEach( function( form ) {
			beforeUnloadForm( form );
		} );
	} );
</script>
