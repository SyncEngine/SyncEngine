<script id="script_globals">
	window.app = {
		env: "{{ app.environment }}",
		debug: {{ app.debug ? 'true' : 'false' }},
		baseUrl: "{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}",
		endpoints: {
			models: {
				tasks: "{{ url( 'json_tasks' ) }}",
				webservices: "{{ url( 'json_webservices' ) }}",
			},
			entities: {
				automation: "{{ url( 'json_automation' ) }}",
				connection: "{{ url( 'json_connection' ) }}",
				flow: "{{ url( 'json_flow' ) }}",
				step: "{{ url( 'json_step' ) }}",
				dataset: "{{ url( 'json_dataset' ) }}",
			},
			requests: {
				automation: "{{ url( 'api_automation' ) }}",
				connection: "{{ url( 'api_connection' ) }}",
				dataset: "{{ url( 'api_dataset' ) }}",
			},
		},
		models: {},
		entities: {},
		forms: {
			register: function( element ) {
				var ref = element.id + '_' + element.name;

				function remove() {
					window.app.forms.changed.splice(
						window.app.forms.changed.indexOf( ref ),
						1,
					);
				}

				function add() { window.app.forms.changed.push( ref ); }

				// Native.
				element.addEventListener( 'change', add, false );
				element.addEventListener( 'submit', window.app.forms.clear, false );
				// AJAX/React
				element.addEventListener( 'submitted', remove, false );
				element.addEventListener( 'removed', remove, false );
            },
			clear: function() { window.app.forms.changed = [] },
			changed: [],
		},
		preferences: {
			menuCollapsed: 1 == localStorage.getItem( 'menu-collapsed' ),
		},
		init: function () {
			var menu = document.getElementById( 'menu' );
			if ( menu ) {
				menu.classList.add( window.app.preferences.menuCollapsed ? 'collapsed' : 'expanded' );
				document.getElementById( 'main' ).classList.add( window.app.preferences.menuCollapsed ? 'menu-collapsed' : 'menu-expanded' );
			}

			Array.from( document.getElementsByTagName( 'form' ) ).forEach( function ( form ) {
				window.app.forms.register( form );
			} );
		},
	};

	window.onbeforeunload = function () {
		if ( window.app.forms.changed.length ) {
			return 'You have unsaved changes! If you leave this page, your changes will be lost.';
		}
	};
</script>
