
{% if error %}
	<div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
{% endif %}

<form action="{{ path('app_login') }}" method="post" class="">
	<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
	{# If you want to control the URL the user is redirected to on success
        <input type="hidden" name="_target_path" value="/account"> #}

	<div class="form-floating mb-3">
		<input class="form-control" type="text" id="username" name="_username" value="{{ last_username }}" placeholder="{% trans %}Email{% endtrans %}">
		<label for="username">{% trans %}Email{% endtrans %}</label>
	</div>

	<div class="form-floating mb-3">
		<input class="form-control" type="password" id="password" name="_password" placeholder="{% trans %}Password{% endtrans %}">
		<label for="password">{% trans %}Password{% endtrans %}</label>
	</div>

	<button type="submit" class="btn btn-primary">{% trans %}login{% endtrans %}</button>
</form>
