
{% if error %}
	<div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
{% endif %}

<form action="{{ path('app_login') }}" method="post" class="">
	<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
	{# If you want to control the URL the user is redirected to on success
        <input type="hidden" name="_target_path" value="/account"> #}

	<div class="form-floating mb-3">
		<input class="form-control" type="text" id="username" name="_username" value="{{ last_username }}" placeholder="{{ 'Email'|trans }}">
		<label for="username">{{ 'Email'|trans }}</label>
	</div>

	<div class="form-floating mb-3">
		<input class="form-control" type="password" id="password" name="_password" placeholder="{{ 'Password'|trans }}">
		<label for="password">{{ 'Password'|trans }}</label>
	</div>

	<button type="submit" class="btn btn-primary">{{ 'Login'|trans }}</button>
</form>
