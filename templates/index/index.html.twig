{% extends 'base.html.twig' %}

{% block title %}Kerall Connect{% endblock %}

{% block body %}

	<div class="btn-group" role="group">
		<a class="btn btn-connection" href="{{ path('create_connection') }}">New connection</a>
		<a class="btn btn-automation" href="{{ path('create_automation') }}">New automation</a>
		<a class="btn btn-flow" href="{{ path('create_flow') }}">New flow</a>
		<a class="btn btn-step" href="{{ path('create_step') }}">New step</a>
		<a class="btn btn-dataset" href="{{ path('create_dataset') }}">New dataset</a>
	</div>

	{% if connections %}
		<div class="card my-3">
			<div class="card-header text-bg-connection d-flex justify-content-between align-items-center">
				<div><i class="bi bi-cloud lead align-middle me-2"></i> Connections</div>
				<a class="btn btn-outline-dark" href="{{ path('create_connection') }}">Create new</a></div>
			<div class="card-body">
				<table class="table table-hover table-responsive align-middle">
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th class="text-end">Actions</th>
					</tr>
					{% for connection in connections %}
						<tr>
							<td>{{ connection.name }}</td>
							<td>{{ connection.description }}</td>
							<td class="text-end">
								<a class="btn btn-connection" href="{{ path('edit_connection', {id:connection.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}

	{% if automations %}
		<div class="card my-3">
			<div class="card-header text-bg-automation d-flex justify-content-between align-items-center">
				<div><i class="bi bi-diagram-3 lead align-middle me-2"></i> Automations</div>
				<a class="btn btn-automation btn-outline-dark" href="{{ path('create_automation') }}">Create new</a>
			</div>
			<div class="card-body">
				<table class="table table-hover table-responsive align-middle">
					<tr>
						<th>Name / Description</th>
						<th>Source &raquo; Target</th>
						<th>URL</th>
						<th>Flow</th>
						<th class="text-end table-cell-shrink">Actions</th>
					</tr>
					{% for automation in automations %}
						<tr>
							<td>{{ automation.name }}<br><small>{{ automation.description }}</small></td>
							<td>{{ automation.sourceConnection.name }} &raquo; {{ automation.targetConnection.name }}</td>
							<td>{{ app.request.getSchemeAndHttpHost() }}{{ path('api', {endpoint:automation.endpoint}) }}</td>
							<td>
								{% if automation.flow %}
									<a href="{{ path('edit_flow', {id:automation.flow.id}) }}">{{ automation.flow.name }}</a>
								{% endif %}
							</td>
							<td class="text-end">
								<a class="btn btn-automation" href="{{ path('edit_automation', {id:automation.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


	{% if flows %}
		<div class="card my-3">
			<div class="card-header text-bg-flow d-flex justify-content-between align-items-center">
				<div><i class="bi bi-command lead align-middle me-2"></i> Flows</div>
				<a class="btn btn-outline-dark btn-flow" href="{{ path('create_flow') }}">Create new</a></div>
			<div class="card-body">
				<table class="table table-hover table-responsive align-middle">
					<tr>
						<th>Name / Description</th>
						<th>Used in</th>
						<th>Steps</th>
						<th class="text-end table-cell-shrink">Actions</th>
					</tr>
					{% for flow in flows %}
						<tr>
							<td>
								{{ flow.name }}<br><small>{{ flow.description }}</small>
							</td>
							<td>
								<div class="list-group">
								{% for automation in flow.automations %}
									<a href="{{ path('edit_automation', {id:automation.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
										{{ automation.name }}
										<span class="badge text-bg-automation rounded-pill">Automation</span>
									</a>
								{% endfor %}
								{% if steps %}
									{% for _step in steps %}
										{% for task in _step.config.tasks %}
											{% if ( task.flow is defined and step.id in task.flow ) or ( task.flows is defined and step.id in task.flows ) %}
												<a href="{{ path('edit_step', {id:_step.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
													{{ _step.name }}
													<span class="badge text-bg-step rounded-pill">Step</span>
												</a>
											{% endif %}
										{% endfor %}
									{% endfor %}
								{% endif %}
								</div>
							</td>
							<td>
								{% if flow.steps %}
								<div class="list-group">
									{% for index, step in flow.steps %}
										{% for _step in steps %}
											{% if step == _step.id %}
												<a href="{{ path('edit_step', {id:_step.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
													{{ index +1 }}: {{ _step.name }}
												</a>
											{% endif %}
										{% endfor %}
									{% endfor %}
								</div>
								{% endif %}
							</td>
							<td class="text-end">
								<a class="btn btn-flow" href="{{ path('edit_flow', {id:flow.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


	{% if steps %}
		<div class="card my-3">
			<div class="card-header text-bg-step d-flex justify-content-between align-items-center">
				<div><i class="bi bi-collection lead align-middle me-2"></i> Steps</div>
				<a class="btn btn-outline-dark" href="{{ path('create_step') }}">Create new</a>
			</div>
			<div class="card-body">
				<table class="table table-hover table-responsive align-middle">
					<tr>
						<th>Name / Description</th>
						<th>Used in</th>
						<th>Config</th>
						<th class="text-end table-cell-shrink">Actions</th>
					</tr>
					{% for step in steps %}
						<tr>
							<td>{{ step.name }}<br><small>{{ step.description }}</small></td>
							<td>
								<div class="list-group">
								{% if flows %}
									{% for flow in flows %}
										{% if step.id in flow.steps %}
											<a href="{{ path('edit_flow', {id:flow.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
												{{ flow.name }}
												<span class="badge text-bg-flow rounded-pill">Flow</span>
											</a>
										{% endif %}
									{% endfor %}
								{% endif %}
								{% for _step in steps %}
									{% for task in _step.config.tasks %}
										{% if ( task.step is defined and step.id in task.step ) or ( task.steps is defined and step.id in task.steps ) %}
											<a href="{{ path('edit_step', {id:_step.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
												{{ _step.name }}
												<span class="badge text-bg-step rounded-pill">Step</span>
											</a>
										{% endif %}
									{% endfor %}
								{% endfor %}
								</div>
							</td>
							<td>
								<ul class="list-group">
									{% for task in step.config.tasks %}
										<li class="list-group-item">{{ task.label ?? '' }} <span class="badge text-bg-task rounded-pill">Task: {{ task.type }}</span></li>
									{% endfor %}
								</ul>
							</td>
							<td class="text-end">
								<a class="btn btn-step" href="{{ path('edit_step', {id:step.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


	{% if datasets %}
		<div class="card my-3">
			<div class="card-header text-bg-dataset d-flex justify-content-between align-items-center">
				<div><i class="bi bi-database lead align-middle me-2"></i>Datasets</div>
				<a class="btn btn-outline-dark" href="{{ path('create_dataset') }}">Create new</a></div>
			<div class="card-body">
				<table class="table table-hover table-responsive align-middle">
					<tr>
						<th>Name / Description</th>
						<th>Used in</th>
						<th>Config</th>
						<th class="text-end table-cell-shrink">Actions</th>
					</tr>
					{% for dataset in datasets %}
						<tr>
							<td>{{ dataset.name }} <span class="badge text-bg-dataset rounded-pill">{{ dataset.type }}</span><br><small>{{ dataset.description }}</small></td>
							<td>
								<div class="list-group">
									TODO
								</div>
							</td>
							<td>
								<ul class="list-group list-group-horizontal">
								{% for column in dataset.config.columns %}
									<li class="list-group-item">{{ column.name }}</li>
								{% endfor %}
								</ul>
							</td>
							<td class="text-end">
								<a class="btn btn-dataset" href="{{ path('edit_dataset', {id:dataset.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


{% endblock %}
