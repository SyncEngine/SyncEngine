{% extends 'base.html.twig' %}

{% block title %}Kerall Connect{% endblock %}

{% block body %}

	<div class="btn-group" role="group">
		<a class="btn btn-primary" href="{{ path('create_connection') }}">New connection</a>
		<a class="btn btn-primary" href="{{ path('create_flow') }}">New flow</a>
		<a class="btn btn-primary" href="{{ path('create_automation') }}">New automation</a>
	</div>

	{% if connections %}
		<div class="card my-3">
			<div class="card-header">Connections</div>
			<div class="card-body">
				<table class="table">
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Actions</th>
					</tr>
					{% for connection in connections %}
						<tr>
							<td>{{ connection.name }}</td>
							<td>{{ connection.description }}</td>
							<td>
								<a href="{{ path('edit_connection', {id:connection.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}

	{% if automations %}
		<div class="card my-3">
			<div class="card-header">Automations</div>
			<div class="card-body">
				<table class="table">
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Source &raquo; Target</th>
						<th>URL</th>
						<th>Flow</th>
						<th>Actions</th>
					</tr>
					{% for automation in automations %}
						<tr>
							<td>{{ automation.name }}</td>
							<td>{{ automation.description }}</td>
							<td>{{ automation.sourceConnection.name }} &raquo; {{ automation.targetConnection.name }}</td>
							<td>{{ app.request.getSchemeAndHttpHost() }}{{ path('api', {endpoint:automation.endpoint}) }}</td>
							<td>{{ automation.flow.name }}</td>
							<td>
								<a href="{{ path('edit_automation', {id:automation.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


	{% if flows %}
		<div class="card my-3">
			<div class="card-header">Flows</div>
			<div class="card-body">
				<table class="table">
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Used in</th>
						<th>Actions</th>
					</tr>
					{% for flow in flows %}
						<tr>
							<td>{{ flow.name }}</td>
							<td>{{ flow.description }}</td>
							<td>
								{% for automation in flow.automations %}
									Automation: {{ automation.name }},
								{% endfor %}
								{% if steps %}
									{% for _step in steps %}
										{% for task in _step.config.tasks %}
											{% if ( task.flow is defined and step.id in task.flow ) or ( task.flows is defined and step.id in task.flows ) %}
												Step: {{ _step.name }},
											{% endif %}
										{% endfor %}
									{% endfor %}
								{% endif %}
							</td>
							<td>
								<a href="{{ path('edit_flow', {id:flow.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


	{% if steps %}
		<div class="card my-3">
			<div class="card-header">Steps</div>
			<div class="card-body">
				<table class="table">
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Used in</th>
						<th>Config</th>
						<th>Actions</th>
					</tr>
					{% for step in steps %}
						<tr>
							<td>{{ step.name }}</td>
							<td>{{ step.description }}</td>
							<td>
								{% if flows %}
									{% for flow in flows %}
										{% if step.id in flow.steps %}
											Flow: {{ flow.name }},
										{% endif %}
									{% endfor %}
								{% endif %}
								{% for _step in steps %}
									{% for task in _step.config.tasks %}
										{% if ( task.step is defined and step.id in task.step ) or ( task.steps is defined and step.id in task.steps ) %}
											Step: {{ _step.name }},
										{% endif %}
									{% endfor %}
								{% endfor %}
							</td>
							<td>
								{{ step.config|json_encode() }}
							</td>
							<td>
								<a href="{{ path('edit_step', {id:step.id}) }}">Edit</a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}


{% endblock %}
