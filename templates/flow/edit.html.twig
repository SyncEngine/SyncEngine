{% extends 'base.html.twig' %}

{% block title %}Edit Flow: {{ flow.name }}{% endblock %}

{% block body %}
	<h1>Flow: {{ flow.name }}</h1>

	<div id="edit_flow_{{ flow.id }}">
		<div class="card">
			<div class="card-header">Edit Flow</div>
			<div class="card-body">
				{{ form(form) }}
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col">
			<div class="card my-3">
				<div class="card-header">Add existing step</div>
				<div class="card-body">
					{{ form(formAddStep) }}
				</div>
			</div>
		</div>
		<div class="col">
			<div class="card my-3">
				<div class="card-header">Create new step</div>
				<div class="card-body">
					<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newStepModal">
						Create new step
					</button>
				</div>
			</div>
		</div>
	</div>

	<div class="modal fade" id="newStepModal" tabindex="-1" aria-labelledby="newStepModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
			<div class="modal-content">
				<div class="modal-header">
					<h1 class="modal-title fs-5" id="newStepModalLabel">Create new step</h1>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					{{ form(formCreateStep) }}
				</div>
			</div>
		</div>
	</div>


{% endblock %}
