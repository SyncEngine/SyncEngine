{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Connections'|trans({},'core') }}{% endblock %}

{% block content %}

	{% if connections %}
		<div class="card my-3">
			<div class="card-header bg-connection-subtle d-flex justify-content-between align-items-center">
				<div class="d-flex align-items-center gap-2"><i class="bi bi-cloud lead"></i> {{ 'Connections'|trans({},'core') }}</div>
				<a class="btn btn-connection" href="{{ path('create_connection') }}">{{ 'Create new'|trans({},'core') }}</a></div>
			<div class="card-body table-responsive">
				<table class="table table-hover align-middle">
					<tr>
						<th class="text-start table-cell-shrink">#</th>
						<th>{{ 'Name'|trans({},'core') }}</th>
						<th>{{ 'Description'|trans({},'core') }}</th>
						<th>{{ 'Config'|trans({},'core') }}</th>
						<th class="text-end">{{ 'Actions'|trans({},'core') }}</th>
					</tr>
					{% for connection in connections %}
						<tr>
							<td>{{ connection.id }}</td>
							<td>{{ connection.name }}</td>
							<td>{{ connection.description }}</td>
							<td>
								<div class="list-group">
									{% if connection.config.webservice is defined %}
										<li class="list-group-item d-flex justify-content-between align-items-center gap-2">
											{{ connection.config.webservice.host ?? '--' }} <span class="badge text-bg-webservice rounded-pill">{{ 'Webservice'|trans({},'core') }}: {{ connection.config.webservice._class ?? '' }}</span>
										</li>
									{% endif %}
								</div>
							</td>
							<td class="text-end">
								<a class="btn btn-connection" href="{{ path('edit_connection', {id:connection.id}) }}"><i class="bi-pencil-fill"></i></a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}

{% endblock %}
