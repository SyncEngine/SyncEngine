{% set header = header ?? {
	icon: 'bi-cloud',
	title: 'Connections'|trans,
	actions: [ 'create' ],
} %}

{% set columns = columns ?? {
	entities: {
		label: 'Used in'|trans,
		prop: '_dependents',
	},
	webservice: {
		block: 'info',
		label: 'Webservice'|trans,
		type: 'webservice',
		value: '{{ config.webservice._class }}',
		parse: 'tag|model',
		badge: {
			options: [
				{
					compare: 'false',
					value: '{{ data.connected }}',
					label: 'Issue'|trans,
					type: 'warning',
				},
				{
					compare: 'true',
					value: '{{ data.connected }}',
					label: 'Connected'|trans,
					type: 'success',
				}
			]
		},
		sub: {
			value: '{{ config.webservice.host }}',
			parse: 'tag',
		}
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'connection',
	entity: true,
} %}
