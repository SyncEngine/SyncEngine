{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Datasets'|trans }}{% endblock %}

{% block content %}

	{% include 'admin/_partials/list.html.twig' with {
		type: 'dataset',
		entity: true,
		header: {
			icon: 'bi-database',
			title: 'Datasets'|trans,
			actions: [ 'create' ],
		},
		total: list.total ?? null,
		items: list.items ?? null,
		query: list.query ?? { limit: 10, total: true, relations: true },
		columns: list.columns ?? {
			entities: {
				label: 'Used in'|trans,
				prop: '_dependents',
			},
			config: {
				label: "Columns",
				prop: 'columns',
			}
		}
	} %}

{% endblock %}
