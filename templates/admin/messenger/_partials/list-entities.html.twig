{% set messengerList = [] %}
{% for it in messenger.items %}
	{% set messengerList = messengerList|merge([
		it|merge({
			'automationID': it.body.automationId,
			'requestParams': it.body.requestParams,
			'requestQuery': it.body.requestQuery
		})
	]) %}
{% endfor %}
{% include 'admin/_partials/react/ListController.html.twig' with {
	type: 'message_queue',
	entity: true,
	header: header ?? {
		icon: 'queue',
		title: 'Message Queue'|trans,
		actions: [ 'search', 'refresh' ],
	},
	total: total ?? null,
	items: messengerList ?? null,
	query: query ?? { limit: 10, total: true, relations: true },
	columns: columns ?? {
		id: {
			label: 'ID'|trans,
			prop: 'id',
			parse: 'number',
			sortable: true,
		},
		queue_name: {
			label: 'Queue'|trans,
			prop: 'queue_name',
			parse: 'string',
			sortable: true,
			icon: 'queue',
		},
		automationID: {
			label: 'Automation'|trans,
			prop: 'target_automation',
			parse: 'string',
			sortable: true,
			icon: 'queue',
		},
		created_at: {
			label: 'Created At'|trans,
			prop: 'created_at',
			parse: 'date',
			sortable: true,
		},
		available_at: {
			label: 'Available At'|trans,
			prop: 'available_at',
			parse: 'date',
			sortable: true,
		},
		requestParams:   { label: 'requestParams'|trans, parse: 'string', sortable: true },
		requestQuery:   {
			label: 'requestQuery'|trans,
			parse: 'json',
			sortable: true
		},
		body:   {
			label: 'test'|trans,
			type: "entity",
			value: "{{ body.automationId }}",
		},

		actions: {
			label: 'Actions'|trans,
			actions: {
				view: {
					action: 'request',
					request: 'view',
					label: 'View'|trans,
					title: 'Message {{ id }}'|trans,
					icon: 'view',
					variant: 'info',
					params: { id: 'entityId' },
				},
				delete: {
					action: 'request',
					request: 'delete',
					label: 'Delete'|trans,
					title: 'Delete Message {{ id }}'|trans,
					icon: 'trash',
					variant: 'danger',
					confirm: 'Are you sure you want to delete this message?'|trans,
					params: { id: 'entityId' },
				},
			},
		},
	}
} %}
