{% set messengerList = [] %}
{% for it in messenger.items %}
	{% set messengerList = messengerList|merge([
		it|merge({
			'requestParams': it.body.requestParams,
			'requestQuery': it.body.requestQuery
		})
	]) %}
{% endfor %}
{% include 'admin/_partials/react/ListController.html.twig' with {
	type: 'message_queue',
	entity: true,
	header: header ?? {
		icon: 'queue',
		title: 'Message Queue'|trans,
		actions: [ 'search', 'refresh' ],
	},
	total: total ?? null,
	items: messengerList ?? null,
	query: query ?? { limit: 10, total: true, relations: true },
	columns: columns ?? {
		id: {
			label: 'ID'|trans,
			prop: 'id',
			parse: 'number',
			sortable: true,
		},
		queue_name: {
			label: 'Queue'|trans,
			prop: 'queue_name',
			parse: 'string',
			sortable: true,
			icon: 'queue',
		},
		automation: {
			label: 'Automation'|trans,
			block: 'entities',
			prop: 'automation',
			multi: false,
		},
		created_at: {
			label: 'Created At'|trans,
			prop: 'created_at',
			parse: 'date',
			sortable: true,
		},
		available_at: {
			label: 'Scheduled At'|trans,
			prop: 'available_at',
			parse: 'date',
			sortable: true,
		},
		requestParams: {
			label: 'Params'|trans,
			parse: 'string',
			sortable: true
		},
		requestQuery: {
			label: 'Query'|trans,
			parse: 'json',
			sortable: true
		},
		actions: {
			label: 'Actions'|trans,
			actions: {
				view: {
					action: 'request',
					request: 'view',
					label: 'View'|trans,
					title: 'Message {{ id }}'|trans,
					icon: 'view',
					variant: 'info',
					params: { id: 'entityId' },
				},
				delete: {
					action: 'request',
					request: 'delete',
					label: 'Delete'|trans,
					title: 'Delete Message {{ id }}'|trans,
					icon: 'trash',
					variant: 'danger',
					confirm: 'Are you sure you want to delete this message?'|trans,
					params: { id: 'entityId' },
				},
			},
		},
	}
} %}
