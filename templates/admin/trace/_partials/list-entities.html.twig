{% include 'admin/_partials/react/ListController.html.twig' with {
	type: 'trace',
	entity: true,
	header: header ?? {
		icon: 'trace',
		title: 'Traces'|trans,
		actions: [ 'search', 'create' ],
	},
	total: total ?? null,
	items: items ?? null,
	query: query ?? { limit: 10, total: true, relations: true },
	columns: columns ?? {
		info      : {
			label: 'Date'|trans,
			prop: 'created',
			parse: 'date',
		},
		status: {
			label: 'Status'|trans,
			block: 'info',
			value: '',
			badge: {
				type: 'info',
				label: '{{ status }}',
				icon: 'trace-status',
				options: [
					{
						compare: 'running',
						value: '{{ status }}',
						label: 'Running'|trans,
						icon: 'trace-info'
					},
					{
						compare: 'scheduled',
						value: '{{ status }}',
						label: 'Scheduled'|trans,
						icon: 'event-schedule'
					},
					{
						compare: 'cancelled',
						value: '{{ status }}',
						label: 'Cancelled'|trans,
						type: 'secondary',
						icon: 'event-cancel'
					},
					{
						compare: 'stopped',
						value: '{{ status }}',
						label: 'Stopped'|trans,
						type: 'secondary',
						icon: 'event-stop'
					},
					{
						compare: 'failed',
						value: '{{ status }}',
						label: 'Failed'|trans,
						type: 'warning',
						icon: 'event-error'
					},
					{
						compare: 'success',
						value: '{{ status }}',
						label: 'Success'|trans,
						type: 'success',
						icon: 'event-success'
					}
				]
			},
		},
		automation: {
			label: 'Automation'|trans,
			block: 'entities',
			prop: 'automation',
			multi: false,
		},
		actions: {
			label: 'Info'|trans,
			view: 'buttons',
			actions: {
				kill: {
					conditions: {
						status: 'running',
					},
					action: 'request',
					confirm: 'You are about to kill this process, are you sure?'|trans,
					request: 'kill',
					label: 'Kill'|trans,
					title: 'Kill'|trans ~ ': ' ~ 'Trace'|trans ~ ' {{ created }}: {{ automation.name }} ({{ status }})',
					icon: 'event-stop',
					variant: 'danger',
					params: { id: 'entityId' },
				},
				view: {
					action: 'request',
					confirm: false,
					request: 'view',
					label: 'View'|trans,
					title: 'Trace'|trans ~ ' {{ created }}: {{ automation.name }} ({{ status }})',
					icon: 'view',
					variant: 'info',
					params: { id: 'entityId' },
				},
				delete: 'Delete'|trans,
			},
		},
	},
	footer: footer ?? {
		actions: [ 'loadmore' ]
	},
} %}
