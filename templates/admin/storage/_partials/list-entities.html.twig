{% set header = header ?? {
	icon: 'storage',
	title: 'Storages'|trans,
	actions: [ 'search', 'create' ],
} %}

{% set columns = columns ?? {
	info: {
		label: 'Info'|trans,
		badge: {
			label: '{{ type }}',
			icon: 'storage-{{ type }}',
		},
	},
	supervisor: {
		block: 'info',
		label: 'Module'|trans,
		value: '',
		badge: {
			label: '{{ supervisor.module }}',
			icon: 'module',
		},
	},
	entities: {
		label: 'Used in'|trans,
		prop: '_dependents',
	},
	config: {
		label: "Columns",
		prop: 'columns',
		inline: true,
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'storage',
	entity: true,
} %}
