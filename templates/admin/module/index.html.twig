{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Modules'|trans }}{% endblock %}

{% block content %}
	<div class="card my-3">
		<div class="card-header d-flex justify-content-between align-items-center">
			<div class="d-flex align-items-center gap-2">{% include '_partials/icon.html.twig' with { icon: 'module', class: 'lead' } %} {{ 'Modules'|trans }}</div>
			<a class="btn btn-primary btn-subtle" href="{{ path('syncengine_module_upload') }}">{{ 'Upload'|trans }}</a>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<table class="table table-hover align-middle">
					<tr>
						<th>{{ 'Name'|trans }}</th>
						<th>{{ 'Description'|trans }}</th>
						<th>{{ 'Version'|trans }}</th>
						<th>{{ 'Author'|trans }}</th>
						<th class="text-end">{{ 'Actions'|trans }}</th>
					</tr>
					{% for module in modules %}
						{% if module.name %}
							<tr>
								<td>{{ module.name }}</td>
								<td>{{ module.description }}</td>
								<td>{{ module.version }}</td>
								<td>{{ module.author ?: module._vendor }}</td>
								<td class="text-end">
									{% if module._has_admin %}
									<a class="btn btn-primary btn-subtle"
									   href="{{ path('syncengine_module', {module:module._module, vendor:module._vendor}) }}"
									   title="{{ 'Manage'|trans }}"
									>
										{% include '_partials/icon.html.twig' with { icon: 'module' } %}
									</a>
									{% endif %}
									<a class="btn btn-warning btn-subtle"
									   href="{{ path('syncengine_module_install_run', {moduleName:module._module, vendor:module._vendor, previousVersion:0}) }}"
									   title="{{ 'Reinstall'|trans }}"
									>
										{% include '_partials/icon.html.twig' with { icon: 'reboot' } %}
									</a>
									<a class="btn btn-danger btn-subtle"
									   href="{{ path('syncengine_module_uninstall', {module:module._module, vendor:module._vendor}) }}"
									   title="{{ 'Uninstall'|trans }}"
									>
										{% include '_partials/icon.html.twig' with { icon: 'delete' } %}
									</a>
								</td>
							</tr>
						{% endif %}
					{% endfor %}
				</table>
			</div>
		</div>
	</div>
{% endblock %}
