{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Modules'|trans }}{% endblock %}

{% block content %}
	{% if disabled_modules is defined and disabled_modules|length %}
		<div class="alert alert-warning my-3" role="alert">
			<div class="fw-semibold pointer-event" data-bs-toggle="collapse" data-bs-target="#disabledModules" aria-expanded="false" aria-controls="disabledModules">{{ 'Disabled modules.'|trans }}</div>
			<div id="disabledModules" class="collapse show">
				<div class="table-responsive mt-2">
					<table class="table table-sm table-transparent align-middle mb-0">
						<tr>
							<th>{{ 'Module'|trans }}</th>
							<th>{{ 'Requires'|trans }}</th>
							<th>{{ 'Reason'|trans }}</th>
							<th>{{ 'Actions'|trans }}</th>
						</tr>
						{% for disabled in disabled_modules %}
							<tr>
								<td>{{ disabled.package ?? (disabled.vendor ~ '/' ~ disabled.module) }}</td>
								<td>{{ disabled.constraint ?: '-' }}</td>
								<td>{{ disabled.reason ?: '-' }}</td>
								<td>
									<a class="btn btn-primary btn-subtle"
									   href="{{ path('syncengine_module_enable', {moduleName: disabled.module, vendor: disabled.vendor}) }}"
									   title="{{ 'Enable'|trans }}"
									>
										{% include '_partials/icon.html.twig' with { icon: 'enable' } %}
									</a>
									<a class="btn btn-danger btn-subtle"
									   data-bs-toggle="modal"
									   data-bs-target="#module-uninstall-{{ disabled.package ?? (disabled.vendor ~ '/' ~ disabled.module) }}"
									   title="{{ 'Uninstall'|trans }}"
									>
										{% include '_partials/icon.html.twig' with { icon: 'delete' } %}
									</a>

									<div class="modal" id="module-uninstall-{{ disabled.package ?? (disabled.vendor ~ '/' ~ disabled.module) }}" tabindex="-1" data-bs-backdrop="false">
										<div class="modal-dialog">
											<div class="modal-content">
												<div class="modal-header">
													<h5 class="modal-title">{{ 'Are you sure?'|trans }}</h5>
													<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
												</div>
												<div class="modal-body">
													{{ 'This will uninstall module {moduleName} from {vendor}'|trans( { moduleName: disabled.module, vendor: disabled.vendor } ) }}
												</div>
												<div class="modal-footer">
													<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
													<button type="button" class="btn btn-danger" href="{{ path( 'syncengine_module_uninstall', { moduleName: disabled.module, vendor: disabled.vendor } ) }}">{{ 'Uninstall'|trans }}</button>
												</div>
											</div>
										</div>
									</div>
								</td>
							</tr>
						{% endfor %}
					</table>
				</div>
				<div class="mt-2 small">{{ 'Upload a newer module version to replace an incompatible module.'|trans }}</div>
			</div>
		</div>
	{% endif %}

	<div class="card my-3">
		<div class="card-header d-flex justify-content-between align-items-center">
			<div class="d-flex align-items-center gap-2">{% include '_partials/icon.html.twig' with { icon: 'module', class: 'lead' } %} {{ 'Modules'|trans }}</div>
			<a class="btn btn-primary btn-subtle" href="{{ path('syncengine_module_upload') }}">{{ 'Upload'|trans }}</a>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<table class="table table-hover align-middle">
					<tr>
						<th class="col-icon"></th>
						<th class="col-name">{{ 'Name'|trans }}</th>
						<th class="col-description">{{ 'Description'|trans }}</th>
						<th class="col-version">{{ 'Version'|trans }}</th>
						<th class="col-vendor">{{ 'Author'|trans }}</th>
						<th class="col-actions text-end">{{ 'Actions'|trans }}</th>
					</tr>
					{% for module in modules %}
						{% if module.name %}
							{% set vendor = module.author ?: module._vendor %}
							<tr>
								<td class="col-icon">
									{% if module.icon %}
										{% include '_partials/icon.html.twig' with { icon: module.icon } %}
									{% endif %}
								</td>
								<td class="col-name">{{ module.name }}</td>
								<td class="col-description">{{ module.description }}</td>
								<td class="col-version">{{ module.version }}</td>
								<td class="col-vendor">{{ vendor }}</td>
								<td class="col-actions text-end">
									<div class="d-flex justify-content-end">
										{% if module._has_admin %}
										<a class="btn btn-primary btn-subtle"
										   href="{{ path('syncengine_module', {moduleName:module._module, vendor:module._vendor}) }}"
										   title="{{ 'Manage'|trans }}"
										>
											{% include '_partials/icon.html.twig' with { icon: 'module' } %}
										</a>
										{% endif %}

										<div class="dropdown d-inline-block">
											<button class="btn btn-outline-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false">
												{% include '_partials/icon.html.twig' with { icon: 'ellipsis-vertical' } %}
											</button>
											<ul class="dropdown-menu p-0">
												<li>
													<a class="dropdown-item p-2 list-group-item list-group-item-action list-group-item-warning btn-subtle"
													   href="{{ path('syncengine_module_install_run', {moduleName:module._module, vendor:module._vendor, previousVersion:0}) }}"
													   title="{{ 'Reinstall'|trans }}"
													>
														{% include '_partials/icon.html.twig' with { icon: 'reboot' } %} {{ 'Reinstall'|trans }}
													</a>
												</li>
												<li>
													<a class="dropdown-item p-2 list-group-item list-group-item-action list-group-item-danger btn-subtle"
													   href="{{ path('syncengine_module_disable', {moduleName:module._module, vendor:module._vendor}) }}"
													   title="{{ 'Disable'|trans }}"
													>
														{% include '_partials/icon.html.twig' with { icon: 'disable' } %} {{ 'Disable'|trans }}
													</a>
												</li>
												<li>
													<a class="dropdown-item p-2 list-group-item list-group-item-action list-group-item-danger btn-subtle"
													   data-bs-toggle="modal"
													   data-bs-target="#module-uninstall-{{ module._package }}"
													   title="{{ 'Uninstall'|trans }}"
													>
														{% include '_partials/icon.html.twig' with { icon: 'delete' } %} {{ 'Uninstall'|trans }}
													</a>

													<div class="modal" id="module-uninstall-{{ module._package }}" tabindex="-1" data-bs-backdrop="false">
														<div class="modal-dialog">
															<div class="modal-content">
																<div class="modal-header">
																	<h5 class="modal-title">{{ 'Are you sure?'|trans }}</h5>
																	<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
																</div>
																<div class="modal-body">
																	{{ 'This will uninstall module {moduleName} from {vendor}'|trans( { moduleName: module.name, vendor: vendor } ) }}
																</div>
																<div class="modal-footer">
																	<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
																	<button type="button" class="btn btn-danger" href="{{ path( 'syncengine_module_uninstall', { moduleName:module._module, vendor: module._vendor } ) }}">{{ 'Uninstall'|trans }}</button>
																</div>
															</div>
														</div>
													</div>
												</li>
											</ul>
										</div>
									</div>
								</td>
							</tr>
						{% endif %}
					{% endfor %}
				</table>
			</div>
		</div>
	</div>
{% endblock %}
