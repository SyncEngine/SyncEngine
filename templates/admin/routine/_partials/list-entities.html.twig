{% set header = header ?? {
	icon: 'routine',
	title: 'Routines'|trans,
	actions: [ 'search', 'create' ],
} %}

{% set columns = columns ?? {
	info: {
		label: 'Info'|trans,
		badge: {
			options: [
				{
					compare: true,
					value: '{{ config.conditions }}',
					label: 'Has conditions',
					type: 'info',
				}
			]
		},
	},
	entities: {
		label: 'Used in'|trans,
		prop: '_dependents',
	},
	config: {
		label: 'Config'|trans,
		block: 'condition',
		options: [
			{
				compare: true,
				value: '{{ config._blueprint._class }}',
				type: 'blueprint',
				parse: 'tag|model',
				block: 'info',
				badge: {
					type: 'info',
					label: {
						type: 'blueprint',
						value: '{{ config._blueprint._class }}',
						parse: {
							tag: {},
							model: { prop: 'module' },
						}
					}
				}
			},
			{
				compare: true,
				value: '1',
				block: 'config',
				type: 'task',
				prop: 'tasks',
				badge: {
					type: 'task',
					label: {
						type: 'task',
						prefix: 'Task'|trans ~ ': ',
						value: '{{ _class }}',
						parse: 'tag|model'
					}
				}
			}
		]
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'routine',
	entity: true,
} %}
