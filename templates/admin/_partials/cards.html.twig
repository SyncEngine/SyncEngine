{% if cards is defined and cards is iterable %}
	<div class="row row-cols-1 row-cols-md-2 g-4">
		{% for card in cards %}
			<div class="col">
				<div class="card">
					<h5 class="card-header d-flex gap-2">
						{% if card.icon is defined %}
							<span class="bi bi-{{ card.icon }}"></span>
						{% endif %}
						{{ card.header }}
						{% if card.badge is defined %}
							<span class="badge bg-{{ card.badge.variant ?? 'info' }} float-end">{{ card.badge.text }}</span>
						{% endif %}
					</h5>
					{% if card.body is defined or card.link is defined %}
					<div class="card-body">
						{% if card.body is defined %}
							<p class="card-text">{{ card.body }}</p>
						{% endif %}
						{% if card.link is defined %}
							{% if card.link is iterable %}
								<a href="{{ card.link.url }}" class="btn btn-{{ card.link.variant ?? 'primary' }}{% if card.link.url is empty %} disabled{% endif%}">{{ card.link.text ?? 'More...' }}</a>
							{% else %}
								<a href="{{ card.link }}" class="btn btn-primary{% if card.link is empty %} disabled{% endif%}">{{ card.link_text ?? 'More...' }}</a>
							{% endif %}
						{% endif %}
					</div>
					{% endif %}
					{% if card.list is defined %}
						<div class="list-group list-group-flush">
						{% for item in card.list %}
							{% if item is iterable %}

								{% set variant = item.variant ?? '' %}
								{% if item.link is defined %}
									{% if item.link is iterable %}
										<a class="list-group-item list-group-item-action{% if variant %} list-group-item-{{ variant }}{% endif %}" href="{{ item.link.url }}" target="{{ item.link.target ?? '' }}">
									{% else %}
										<a class="list-group-item list-group-item-action{% if variant %} list-group-item-{{ variant }}{% endif %}" href="{{ item.link }}">
									{% endif %}
								{% else %}
									<div class="list-group-item{% if variant %} list-group-item-{{ variant }}{% endif %}">
								{% endif %}
									{{ item.text }}
								{% if item.link is defined %}</a>{% else %}</div>{% endif %}

							{% else %}
								<div class="list-group-item">{{ item }}</div>
							{% endif %}
						{% endfor %}
						</div>
					{% endif %}
					{% if card.form is defined %}
						<div class="card-body">
							{% include '_partials/form.html.twig' with { form: card.form } %}
						</div>
					{% endif %}
					{% if card.footer is defined %}
						<div class="card-footer">{{ card.footer }}</div>
					{% endif %}
				</div>
			</div>
		{% endfor %}
	</div>
{% endif %}
