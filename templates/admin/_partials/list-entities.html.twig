{% set columns = columns ?? {} %}
{% set firstColumns = firstColumns ?? {
	ref: '#',
	info: {
		label: 'Info',
		badge: '{{ type }}',
	},
	date: {
		block: 'info',
		label: 'Date'|trans,
		icon: false,
		prop: 'created',
		prefix: { icon: 'created' },
		parse: 'date',
		sub: {
			prop: 'modified',
			prefix: { icon: 'modified' },
			parse: 'date',
		},
	},
} %}
{% set lastColumns = lastColumns ?? { actions: { label: 'Actions', actions: [ 'link', 'edit', 'export' ] } } %}

{% set columns = firstColumns|merge( columns ) %}
{% set columns = columns|merge( lastColumns ) %}

{% set footer = footer ?? {
	actions: [
		'total',
		'pagination'
	]
} %}

{% set query = query ?? { limit: 10, total: true, relations: true } %}

