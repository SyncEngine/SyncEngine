
{% if backlink is defined and backlink %}
	{% if backlink is same as( true ) %}
		{% set backlink = breadcrumbs|slice(0,-1)|last %}
	{% endif %}

	{% if backlink is iterable %}
		{% set backlink_url = backlink.link ?? backlink.url ?? '#' %}
		{% set backlink_text = backlink.title ?? backlink.text ?? 'Back' %}
	{% else %}
		{% set backlink_url = backlink ?? '#' %}
		{% set backlink_text = 'Back' %}
	{% endif %}

	<a href="{{ backlink_url }}"{% if backlink_url == '#' %} onclick="history.back()"{% endif %}>
		<span class="bi bi-arrow-left-short"></span>
		{{ backlink_text|trans }}
	</a>
{% endif %}
