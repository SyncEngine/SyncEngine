{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Automations'|trans({},'core') }}{% endblock %}

{% block content %}

	{% include 'admin/_partials/list.html.twig' with {
		type: 'automation',
		entity: true,
		header: {
			icon: 'bi-diagram-3',
			title: 'Automations'|trans({},'core'),
			actions: [ 'create' ],
		},
		total: list.total ?? null,
		items: list.items ?? null,
		query: list.query ?? { limit: 10, total: true, relations: true },
		columns: list.columns ?? {
			link: {
				label: 'URL'|trans({},'core'),
				href: url( 'api_endpoint_profiler', { endpoint: '{endpoint}' } ),
				text: path( 'api_endpoint', { endpoint: '{endpoint}' } ),
			},
			relations: {
				block: 'entities',
				label: 'Used in'|trans({},'core'),
				prop: '_dependents',
			},
			flows: {
				block: 'entities',
				label: 'Flows'|trans({},'core'),
				type: 'flow',
				typeLabel: 'Flow'|trans({},'core'),
				prop: 'config.flow',
				multi: false,
				tags: {
					context: {
						automation: '_entity'
					}
				}
			},
		}
	} %}

{% endblock %}
