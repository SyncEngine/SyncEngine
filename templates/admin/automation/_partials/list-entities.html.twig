{% set header = header ?? {
	icon: 'automation',
	title: 'Automations'|trans,
	actions: [ 'search', 'create' ],
} %}

{% set columns = columns ?? {
	info: {
		label: 'Info'|trans,
		badge: {
			options: [
				{
					compare: true,
					value: '{{ data.running }}',
					label: 'Running',
					type: 'info',
					icon: 'play-circle',
				}
			]
		},
	},
	link: {
		label: 'URL'|trans,
		href: url( 'syncengine_endpoint_execute', { endpoint: '{endpoint}' } ),
		text: path( 'syncengine_api_endpoint_execute', { endpoint: '{endpoint}' } ),
	},
	connections: {
		block: 'entities',
		label: 'Uses'|trans,
		prop: '_dependencies',
	},
} %}

{% set lastColumns = {
	actions: {
		label: 'Actions'|trans,
		actions: {
			reset: {
				conditions: {
					"data.running": true,
				},
				action: 'request',
				confirm: 'You are about to reset this process, are you sure?'|trans,
				request: 'reset',
				label: 'Reset'|trans,
				title: 'Reset automation'|trans ~ ': {{ automation.name }}',
				icon: 'event-stop',
				variant: 'warning',
				params: {
					id: 'entityId',
					action: 'reset',
				},
			},
			link: 'Link'|trans,
			edit: 'Edit'|trans,
			export: 'Export'|trans
		}
	}
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'automation',
	entity: true,
} %}
