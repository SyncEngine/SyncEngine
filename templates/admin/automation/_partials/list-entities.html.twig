{% set header = header ?? {
	icon: 'automation',
	title: 'Automations'|trans,
	actions: [ 'create' ],
} %}

{% set columns = columns ?? {
	info: {
		label: 'Info'|trans,
		badge: {
			options: [
				{
					compare: true,
					value: '{{ data.running }}',
					label: 'Running',
					type: 'info',
				}
			]
		},
	},
	link: {
		label: 'URL'|trans,
		href: url( 'syncengine_endpoint_execute', { endpoint: '{endpoint}' } ),
		text: path( 'syncengine_api_endpoint_execute', { endpoint: '{endpoint}' } ),
	},
	connections: {
		block: 'entities',
		label: 'Uses'|trans,
		prop: '_dependencies',
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'automation',
	entity: true,
} %}
