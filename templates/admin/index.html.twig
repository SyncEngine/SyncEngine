{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	{% if app.debug %}
		<style>.sf-toolbar-clearer{display: none !important;}</style>
	{% endif %}
{% endblock %}

{% block title %}{{ title ?? header ?? 'Admin' }}{% endblock %}

{% block body %}

	<div id="app" class="d-flex min-vh-100 bg-body-tertiary">

		{# {% include 'admin/_partials/menu.twig' %} #}
		{{ render(controller( 'SyncEngine\\Controller\\MenuController::renderMainMenu', {currentPath: path( app.request.attributes.get('_route'), app.request.attributes.get('_route_params') ) } )) }}

		<div id="main" class="flex-grow-1">

			{% include 'admin/_partials/toolbar.twig' %}

			<div id="content" class="container py-4">

				{% for message in app.flashes('warning') %}
					<div class="alert alert-warning">
						{{ message }}
					</div>
				{% endfor %}
				{% for message in app.flashes('success') %}
					<div class="alert alert-success">
						{{ message }}
					</div>
				{% endfor %}

				{% block content %}

					{% include 'admin/_partials/backlink.twig' %}

					{% if header is defined %}
						<h1>
							{% if icon is defined %}
								{% include '_partials/icon.html.twig' with { icon: icon, class: "me-2 small" } %}
							{% endif %}
							{{ header }}
						</h1>
						<hr>
					{% endif %}

					{% if html is defined %}
						{{ html|raw }}
					{% endif %}

					{% if cards is defined %}
						{% include 'admin/_partials/cards.html.twig' with { cards: cards } %}
					{% endif %}

					{% if form is defined %}
						{% include '_partials/form.html.twig' with { form: form } %}
					{% endif %}

				{% endblock %}

			</div>
		</div>
	</div>

{% endblock %}
