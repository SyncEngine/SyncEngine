{% extends 'base.html.twig' %}

{% block title %}{{ title ?? header ?? 'Admin' }}{% endblock %}

{% block body %}

    <div class="d-flex min-vh-100 bg-body-tertiary">

        {% include 'admin/_partials/menu.twig' %}

        <div id="main" class="flex-grow-1">

            {% include 'admin/_partials/toolbar.twig' %}

            <div id="content" class="container py-4">

                {% for message in app.flashes('warning') %}
                    <div class="alert alert-warning">
                        {{ message }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        {{ message }}
                    </div>
                {% endfor %}

                {% block content %}

                    {% if backlink is defined %}
                        {% set backlink_url = backlink is iterable ? backlink.url : backlink %}
                        {% set backlink_text = backlink is iterable ? backlink.text : 'Back'|trans({},'core') %}
                        <a href="{{ backlink_url }}">
                            <span class="bi bi-arrow-left-short"></span>
                            {{ backlink_text }}
                        </a>
                    {% endif %}

                    {% if header is defined %}
                        <h1>{{ header }}</h1>
                        <hr>
                    {% endif %}

                    {% if cards is defined %}
                        {% include 'admin/_partials/cards.html.twig' with { cards: cards } %}
                    {% endif %}

                    {% if form is defined %}
                        {% include '_partials/form.html.twig' with { form: form } %}
                    {% endif %}

                {% endblock %}

            </div>
        </div>
    </div>

{% endblock %}
