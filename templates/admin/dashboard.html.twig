{% extends 'admin/index.html.twig' %}

{% block content %}

	<div class="container">
		<div class="btn-toolbar" role="toolbar">
			<div class="btn-group me-2" role="group">
				<a class="btn btn-connection" href="{{ path('list_connections') }}">{{ 'Connections'|trans }}</a>
				<a class="btn btn-automation" href="{{ path('list_automations') }}">{{ 'Automations'|trans }}</a>
				<a class="btn btn-flow" href="{{ path('list_flows') }}">{{ 'Flows'|trans }}</a>
				<a class="btn btn-step" href="{{ path('list_steps') }}">{{ 'Steps'|trans }}</a>
				<a class="btn btn-dataset" href="{{ path('list_datasets') }}">{{ 'Datasets'|trans }}</a>
			</div>
			<div class="btn-group" role="group">
				<a class="btn btn-primary" href="{{ path('modules') }}">{{ 'Modules'|trans }}</a>
			</div>
		</div>
	</div>

	<div class="container mt-4">
		<div class="row">
			<div class="col">

				<div class="card">
					<h5 class="card-header">Last runs</h5>
					<ul class="list-group list-group-flush">
						<li class="list-group-item d-flex justify-content-between align-items-center">
							DATE | Automation name
							<span class="badge bg-info rounded-pill">14</span>
						</li>
						<li class="list-group-item d-flex justify-content-between align-items-center">
							DATE | Automation name
							<span class="badge bg-warning rounded-pill">3</span>
						</li>
						<li class="list-group-item d-flex justify-content-between align-items-center">
							DATE | Automation name
							<span>
								<span class="badge bg-warning rounded-pill">4</span>
								<span class="badge bg-danger rounded-pill">2</span>
							</span>
						</li>
					</ul>
				</div>

			</div>
			<div class="col">

				<div class="card">
					<h5 class="card-header">Last notifications</h5>
					<ul class="list-group list-group-flush">
						<li class="list-group-item d-flex justify-content-between align-items-center">
							Message
							<span class="badge bg-info rounded-pill">Log</span>
						</li>
						<li class="list-group-item d-flex justify-content-between align-items-center">
							Message
							<span class="badge bg-warning rounded-pill">Warning</span>
						</li>
						<li class="list-group-item d-flex justify-content-between align-items-center">
							Message
							<span class="badge bg-danger rounded-pill">Error</span>
						</li>
					</ul>
				</div>

			</div>
		</div>
	</div>

{% endblock %}
