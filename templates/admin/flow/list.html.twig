{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Flows'|trans({},'core') }}{% endblock %}

{% block content %}

	{% include 'admin/_partials/list.html.twig' with {
		type: 'flow',
		entity: true,
		header: {
			icon: 'bi-command',
			title: 'Flows'|trans({},'core'),
			actions: [ 'create' ],
		},
		total: list.total ?? null,
		items: list.items ?? null,
		query: list.query ?? { limit: 10, total: true, relations: true, dependents: true },
		columns: list.columns ?? {
			relations: {
				block: 'entities',
				label: 'Used in'|trans({},'core'),
				prop: '_dependents',
			},
			automations: {
				block: 'entities',
				label: 'Automations'|trans({},'core'),
				type: 'automation',
				typeLabel: 'Automation'|trans({},'core'),
				prop: 'automations',
			},
			steps: {
				block: 'entities',
				label: 'Steps'|trans({},'core'),
				type: 'step',
				typeLabel: 'Step'|trans({},'core'),
				prop: 'steps',
			},
		}
	} %}

{% endblock %}
