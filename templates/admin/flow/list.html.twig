{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Flows'|trans({},'core') }}{% endblock %}

{% block content %}
	{% if flows %}
		<div class="card my-3">
			<div class="card-header bg-flow-subtle d-flex justify-content-between align-items-center">
				<div class="d-flex align-items-center gap-2"><i class="bi bi-command lead"></i> {{ 'Flows'|trans({},'core') }}</div>
				<a class="btn btn-flow" href="{{ path('create_flow') }}">{{ 'Create new'|trans({},'core') }}</a></div>
			<div class="card-body table-responsive">
				<table class="table table-hover align-middle">
					<tr>
						<th class="text-start table-cell-shrink">#</th>
						<th>{{ 'Name'|trans({},'core') }} / {{ 'Description'|trans({},'core') }}</th>
						<th>{{ 'Used in'|trans({},'core') }}</th>
						<th>{{ 'Steps'|trans({},'core') }}</th>
						<th class="text-end table-cell-shrink">{{ 'Actions'|trans({},'core') }}</th>
					</tr>
					{% for flow in flows %}
						<tr>
							<td>{{ flow.id }}</td>
							<td>{{ flow.name }}<br><small>{{ flow.description }}</small></td>
							<td>
								<div class="list-group">
									{% for automation in flow.automations %}
										<a href="{{ path('edit_automation', {id:automation.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center gap-2">
											{{ automation.name }}
											<span class="badge text-bg-automation rounded-pill">{{ 'Automation'|trans({},'core') }} #{{ automation.id }}</span>
										</a>
									{% endfor %}
									{% if steps %}
										{% for _step in steps %}
											{% if _step.config.tasks is defined %}
												{% for task in _step.config.tasks %}
													{% if ( task.flow is defined and step.id in task.flow ) or ( task.flows is defined and step.id in task.flows ) %}
														<a href="{{ path('edit_step', {id:_step.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center gap-2">
															{{ _step.name }}
															<span class="badge text-bg-step rounded-pill">{{ 'Step'|trans({},'core') }} #{{ _step.id }}</span>
														</a>
													{% endif %}
												{% endfor %}
											{% endif %}
										{% endfor %}
									{% endif %}
								</div>
							</td>
							<td>
								{% if flow.steps %}
									<div class="list-group">
										{% for index, step in flow.steps %}
											{% for _step in steps %}
												{% if step == _step.id %}
													<a href="{{ path('edit_step', {id:_step.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center gap-2">
														{{ index +1 }}: {{ _step.name }} <span class="badge text-bg-step rounded-pill">{{ 'Step'|trans({},'core') }} #{{ _step.id }}</span>
													</a>
												{% endif %}
											{% endfor %}
										{% endfor %}
									</div>
								{% endif %}
							</td>
							<td class="text-end">
								<a class="btn btn-flow" href="{{ path('edit_flow', {id:flow.id}) }}"><i class="bi-pencil-fill"></i></a>
							</td>
						</tr>
					{% endfor %}
				</table>
			</div>
		</div>
	{% endif %}

{% endblock %}
