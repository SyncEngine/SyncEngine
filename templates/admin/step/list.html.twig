{% extends 'admin/index.html.twig' %}

{% block title %}{{ 'Steps'|trans({},'core') }}{% endblock %}

{% block content %}

	{% include 'admin/_partials/list.html.twig' with {
		type: 'step',
		entity: true,
		header: {
			icon: 'bi-collection',
			title: 'Steps'|trans({},'core'),
			actions: [ 'create' ],
		},
		total: list.total ?? null,
		items: list.items ?? null,
		query: list.query ?? { limit: 10, total: true, relations: true },
		columns: list.columns ?? {
			entities: {
				label: 'Used in'|trans({},'core'),
				prop: '_dependents',
			},
			config: {
				label: 'Tasks'|trans({},'core'),
				type: 'task',
				typeLabel: 'Task'|trans({},'core'),
				prop: 'tasks',
			},
		}
	} %}

{% endblock %}
