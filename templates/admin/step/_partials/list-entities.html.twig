{% set header = header ?? {
	icon: 'bi-collection',
	title: 'Steps'|trans,
	actions: [ 'create' ],
} %}

{% set columns = columns ?? {
	entities: {
		label: 'Used in'|trans,
		prop: '_dependents',
	},
	config: {
		label: 'Tasks'|trans,
		type: 'task',
		prop: 'tasks',
		badge: {
			type: 'task',
			label: {
				prefix: 'Task'|trans ~ ': ',
				value: '{{ _class }}',
				parse: 'tag'
			}
		}
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'step',
	entity: true,
} %}
