{% set header = header ?? {
	icon: 'step',
	title: 'Steps'|trans,
	actions: [ 'create' ],
} %}

{% set columns = columns ?? {
	info: {
		label: 'Info'|trans,
		badge: {
			options: [
				{
					compare: true,
					value: '{{ config.conditions }}',
					label: 'Has conditions',
					type: 'info',
				}
			]
		},
	},
	entities: {
		label: 'Used in'|trans,
		prop: '_dependents',
	},
	config: {
		label: 'Tasks'|trans,
		type: 'task',
		prop: 'tasks',
		badge: {
			type: 'task',
			label: {
				type: 'task',
				prefix: 'Task'|trans ~ ': ',
				value: '{{ _class }}',
				parse: 'tag|model'
			}
		}
	},
} %}

{% include 'admin/_partials/list-entities.html.twig' with {
	type: 'step',
	entity: true,
} %}
