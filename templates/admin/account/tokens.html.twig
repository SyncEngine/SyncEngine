{% extends 'admin/index.html.twig' %}

{% block title %}{{ title ?? header ?? 'Tokens'|trans }}{% endblock %}

{% block content %}
	{{ parent() }}

	<div class="card my-3">
		<div class="card-header d-flex justify-content-between align-items-center">
			<div class="d-flex align-items-center gap-2"><i class="bi bi-shield-lock lead"></i> {{ 'Tokens'|trans }}</div>
			<a class="btn btn-primary btn-subtle" href="{{ path('account_tokens_create') }}">{{ 'Create'|trans }}</a></div>
		<div class="card-body">
			<table class="table table-hover table-responsive align-middle">
				<tr>
					<th>{{ 'Description'|trans }}</th>
					<th>{{ 'Token'|trans }}</th>
					<th>{{ 'Expires'|trans }}</th>
					<th class="text-end">{{ 'Actions'|trans }}</th>
				</tr>
				{% if tokens is not empty %}
				{% for token in tokens %}
					{% if token.token %}
						<tr>
							<td>{{ token.description }}</td>
							<td>{{ token.token }}</td>
							<td>{{ token.expires|date }}</td>
							<td class="text-end">
								<a class="btn btn-primary btn-subtle" href="{{ path('account_tokens_edit', { id: token.id }) }}">
									<i class="bi-pencil-fill"></i>
								</a>
								<a class="btn btn-danger btn-subtle"
								   href="{{ path('account_tokens_delete', { id: token.id } ) }}">
									<i class="bi bi-trash-fill"></i>
								</a>
							</td>
						</tr>
					{% endif %}
				{% endfor %}
				{% else %}
					<tr>
						<td colspan="4" class="text-center">{{ 'No tokens created'|trans }}</td>
					</tr>
				{% endif %}
			</table>
		</div>
	</div>
{% endblock %}
